{
  "model": {
    "default": "gpt-5-mini"
  },
  "tools": {
    "allowlist": [],
    "devopsEnabled": false
  },
  "limits": {
    "maxOutputBytes": 200000,
    "maxFileBytes": 1000000,
    "toolTimeoutMs": 4000
  },
  "context": {
    "recentHistoryCount": 5,
    "includeGitSummary": true,
    "includeLastFailure": true
  },
  "ui": {
    "highlightAiBuffer": true,
    "highlightStyle": "underline"
  }
}
