{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MCRN AI Tooling Config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "model": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "default": {
          "type": "string",
          "minLength": 1,
          "default": "gpt-5-mini"
        }
      },
      "default": {
        "default": "gpt-5-mini"
      }
    },
    "tools": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allowlist": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "devopsEnabled": {
          "type": "boolean",
          "default": false
        }
      },
      "default": {
        "allowlist": [],
        "devopsEnabled": false
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxOutputBytes": {
          "type": "integer",
          "minimum": 1024,
          "default": 200000
        },
        "maxFileBytes": {
          "type": "integer",
          "minimum": 1024,
          "default": 1000000
        },
        "toolTimeoutMs": {
          "type": "integer",
          "minimum": 250,
          "default": 4000
        }
      },
      "default": {
        "maxOutputBytes": 200000,
        "maxFileBytes": 1000000,
        "toolTimeoutMs": 4000
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "recentHistoryCount": {
          "type": "integer",
          "minimum": 0,
          "maximum": 20,
          "default": 5,
          "description": "Number of recent shell commands to include in the AI context payload."
        },
        "includeGitSummary": {
          "type": "boolean",
          "default": true,
          "description": "Include current git branch and dirty state in the context payload."
        },
        "includeLastFailure": {
          "type": "boolean",
          "default": true,
          "description": "Include the last failed command and exit code in fix mode."
        }
      },
      "default": {
        "recentHistoryCount": 5,
        "includeGitSummary": true,
        "includeLastFailure": true
      }
    },
    "ui": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "highlightAiBuffer": {
          "type": "boolean",
          "default": true,
          "description": "Apply visual highlighting to AI-generated buffer text."
        },
        "highlightStyle": {
          "type": "string",
          "enum": ["underline", "bold", "standout", "none"],
          "default": "underline",
          "description": "ZSH region_highlight style for AI-generated text."
        }
      },
      "default": {
        "highlightAiBuffer": true,
        "highlightStyle": "underline"
      }
    }
  }
}
